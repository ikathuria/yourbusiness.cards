# YourBusiness.Cards — environment variables.
# Copy to apps/web/.env.local and fill in. Never commit real values.

# --- Supabase (Project Settings → API) ---
NEXT_PUBLIC_SUPABASE_URL=               # project URL
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=   # publishable key (preferred); RLS-protected
NEXT_PUBLIC_SUPABASE_ANON_KEY=          # legacy anon key (fallback if no publishable key)
SUPABASE_SERVICE_ROLE_KEY=              # server-only; webhooks/admin tasks — NEVER expose to client

# --- Stripe (Dashboard → Developers → API keys) ---
STRIPE_SECRET_KEY=                 # server-side secret
STRIPE_WEBHOOK_SECRET=             # from `stripe listen` / dashboard webhook
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_PRO_MONTHLY=          # price ID for the Pro plan
STRIPE_PRICE_PREMIUM_MONTHLY=      # price ID for the Premium (AI) plan

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000   # prod: https://yourbusiness.cards (QR + share + OG links)

# --- Premium AI card generation (Anthropic) ---
ANTHROPIC_API_KEY=                 # Claude API key; server-only, used in /api/generate

# --- Optional ---
NEXT_PUBLIC_GOOGLE_OAUTH=          # set if enabling Google login in Supabase Auth
